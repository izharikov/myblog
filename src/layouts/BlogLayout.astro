---
import { Image, getImage } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import { generateBlogJsonLd } from '@/lib/json-ld';
import { parseDate, formatDate } from '@/lib/date';
import { resolveImage } from '@/lib/images';
import { siteConfig } from '@/config/site';

interface Props {
  title: string;
  description: string;
  date: string;       // DD.MM.YYYY from frontmatter
  slug: string;       // post.id from collection
  logo: string;
  tags: string[];
}

const { title, description, date, slug, logo, tags } = Astro.props;
const logoImage = resolveImage(logo);
const parsedDate = parseDate(date);
const dateDisplay = formatDate(parsedDate);

// Resolve the processed image path for og:image and JSON-LD
let resolvedLogoPath = logo;
if (logoImage) {
  const optimized = await getImage({ src: (await logoImage()).default, width: 1200 });
  resolvedLogoPath = optimized.src;
}
const ogImage = new URL(resolvedLogoPath, siteConfig.site).href;

const jsonLd = generateBlogJsonLd({
  title,
  description,
  date: parsedDate,
  dateDisplay,
  slug,
  logo: resolvedLogoPath,
  tags,
  path: slug,
});
---
<BaseLayout title={title} description={description} ogImage={ogImage} ogType="article" alternateMarkdown={`/blogs/${slug}.md`}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article class="container max-w-screen-xl mx-auto px-4 py-8">
    <header class="mb-8 space-y-4">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
      <div class="flex items-center gap-4 text-sm text-text-secondary">
        <time datetime={parsedDate.toISOString().split('T')[0]}>{dateDisplay}</time>
      </div>
      <div class="flex gap-2 flex-wrap">
        {tags.map(tag => (
          <span class="text-xs font-medium text-accent bg-code-bg px-2 py-0.5 rounded">
            {tag}
          </span>
        ))}
      </div>
      <div class="max-w-[600px] mx-auto">
        {logoImage ? (
          <Image src={logoImage()} alt={title} width={600} height={338} class="rounded-xl w-full h-auto" loading="eager" fetchpriority="high" />
        ) : (
          <img src={logo} alt={title} width="600" height="338" class="rounded-xl w-full h-auto" />
        )}
      </div>
    </header>
    <div class="prose prose-lg max-w-none">
      <slot />
    </div>
    <hr class="my-6" />
    <a class="font-medium text-accent underline underline-offset-4 hover:text-accent-hover transition-colors" href={`/blogs/${slug}.md`} target="_blank">View article as markdown</a>
  </article>
</BaseLayout>
