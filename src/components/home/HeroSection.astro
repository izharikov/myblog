---
import { Image } from 'astro:assets';
import { siteConfig } from '@/config/site';
import profileImg from '@/images/profile.jpg';
---
<section class="py-8 md:py-12 border-b">
  <div class="container max-w-screen-xl mx-auto px-4 flex">
    <div class="pr-8">
      <Image src={profileImg} alt={siteConfig.author.name} width={100} height={100} class="rounded-xl" />
    </div>
    <div class="flex flex-col justify-center space-y-3">
      <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">
        Hello, I'm <span class="text-primary">{siteConfig.author.name}</span>
      </h1>
      <p class="max-w-[700px] text-base text-muted-foreground whitespace-pre-line">
        {siteConfig.description}
      </p>
    </div>
  </div>
</section>
