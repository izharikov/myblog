---
const { class: className, ...rest } = Astro.props;
---
<div class="relative mb-4 mt-6 rounded-lg overflow-hidden border group">
  <button
    class="absolute right-3 top-3 p-1.5 rounded opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity bg-muted hover:bg-accent text-muted-foreground hover:text-accent-foreground z-10"
    aria-label="Copy code"
    data-copy-button
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
      fill="none"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="size-4"
    >
      <rect width="14" height="14" x="8" y="8" rx="2" ry="2" />
      <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
    </svg>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
      fill="none"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="size-4"
    >
      <path d="M20 6 9 17l-5-5" />
    </svg>
  </button>
  <pre class:list={["astro-code overflow-x-auto p-4 text-sm", className]} {...rest}><slot /></pre>
</div>

<style>
  [data-copy-button] svg:last-child { display: none; }
  [data-copy-button][data-copied] svg:first-child { display: none; }
  [data-copy-button][data-copied] svg:last-child { display: block; }
</style>

<script>
  document.querySelectorAll('[data-copy-button]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const wrapper = btn.closest('div');
      const code = wrapper?.querySelector('code');
      const text = code?.innerText ?? '';
      await navigator.clipboard.writeText(text);
      btn.setAttribute('data-copied', '');
      setTimeout(() => btn.removeAttribute('data-copied'), 2000);
    });
  });
</script>
