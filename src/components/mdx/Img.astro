---
import { Image } from 'astro:assets';
import { resolveImage } from '@/lib/images';

const { src, alt, ...rest } = Astro.props;
const resolved = src ? resolveImage(src) : undefined;
---
<span class="my-6 block">
  {resolved ? (
    <Image
      src={resolved()}
      alt={alt || ''}
      class="max-w-full h-auto m-auto border-2"
      {...rest}
    />
  ) : (
    <img
      src={src}
      alt={alt || ''}
      loading="lazy"
      class="max-w-full h-auto m-auto border-2"
      {...rest}
    />
  )}
</span>
