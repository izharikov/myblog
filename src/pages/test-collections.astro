---
// Smoke test page — verifies content collections are working
// DELETE this file in Phase 2 when real pages are built
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => a.data.date.localeCompare(b.data.date));
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Phase 1: Content Collections Smoke Test</title>
  </head>
  <body>
    <h1>Content Collections Smoke Test</h1>
    <p>Total posts found: <strong>{posts.length}</strong> (expected: 9)</p>
    {posts.length !== 9 && (
      <p style="color: red;">WARNING: Expected 9 posts, found {posts.length}</p>
    )}
    <ul>
      {sortedPosts.map((post) => (
        <li>
          <strong>{post.data.title}</strong>
          <br />
          Slug: {post.data.slug ?? post.id} | Date: {post.data.date} | Tags: {post.data.tags.join(', ')}
        </li>
      ))}
    </ul>
  </body>
</html>
