---
import BaseLayout from '../../layouts/BaseLayout.astro';

if (import.meta.env.PROD) {
  return Astro.redirect('/');
}
---

<BaseLayout title="Logo Preview" description="Dev-only logo mark exploration">
  <div class="max-w-screen-xl mx-auto px-4 py-12">
    <div class="mb-8 rounded-lg border bg-surface-alt p-4 text-sm text-text-secondary">
      Dev-only preview &mdash; abstract geometric marks (Option C). Amber accent on surface.
    </div>

    <h1 class="text-3xl font-bold tracking-tight mb-2">Logo Mark Exploration</h1>
    <p class="text-text-secondary mb-12">Option C — abstract geometric, no letters. Shown at header size, favicon 32px, and 16px.</p>

    {/* ── 2D Marks ── */}
    <h2 class="text-2xl font-semibold border-b pb-2 mb-8">2D Flat</h2>

    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-3 mb-16">

      {/* C1 — Diamond */}
      <div>
        <h3 class="font-semibold mb-1">C1 — Diamond</h3>
        <p class="text-sm text-text-secondary mb-4">Rotated square. Simple, bold, geometric.</p>
        <div class="flex items-end gap-6">
          <div>
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="20" y="2" width="25.46" height="25.46" rx="3" transform="rotate(45 20 2)" fill="oklch(0.50 0.18 55)" />
            </svg>
            <p class="text-xs text-text-secondary mt-1">40px</p>
          </div>
          <div>
            <svg width="32" height="32" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="20" y="2" width="25.46" height="25.46" rx="3" transform="rotate(45 20 2)" fill="oklch(0.50 0.18 55)" />
            </svg>
            <p class="text-xs text-text-secondary mt-1">32px</p>
          </div>
          <div>
            <svg width="16" height="16" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="20" y="2" width="25.46" height="25.46" rx="3" transform="rotate(45 20 2)" fill="oklch(0.50 0.18 55)" />
            </svg>
            <p class="text-xs text-text-secondary mt-1">16px</p>
          </div>
        </div>
        <div class="mt-4 flex items-center gap-3 px-3 py-2 rounded-lg bg-surface-alt border w-fit">
          <svg width="24" height="24" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="20" y="2" width="25.46" height="25.46" rx="3" transform="rotate(45 20 2)" fill="oklch(0.50 0.18 55)" />
          </svg>
          <span class="font-bold text-sm">@izharikov</span>
        </div>
      </div>

      {/* C2 — Overlapping planes */}
      <div>
        <h3 class="font-semibold mb-1">C2 — Overlapping Planes</h3>
        <p class="text-sm text-text-secondary mb-4">Two offset rectangles. Depth through overlap.</p>
        <div class="flex items-end gap-6">
          <div>
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="4" y="8" width="22" height="22" rx="3" fill="oklch(0.50 0.18 55)" opacity="0.5" />
              <rect x="14" y="10" width="22" height="22" rx="3" fill="oklch(0.50 0.18 55)" />
            </svg>
            <p class="text-xs text-text-secondary mt-1">40px</p>
          </div>
          <div>
            <svg width="32" height="32" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="4" y="8" width="22" height="22" rx="3" fill="oklch(0.50 0.18 55)" opacity="0.5" />
              <rect x="14" y="10" width="22" height="22" rx="3" fill="oklch(0.50 0.18 55)" />
            </svg>
            <p class="text-xs text-text-secondary mt-1">32px</p>
          </div>
          <div>
            <svg width="16" height="16" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="4" y="8" width="22" height="22" rx="3" fill="oklch(0.50 0.18 55)" opacity="0.5" />
              <rect x="14" y="10" width="22" height="22" rx="3" fill="oklch(0.50 0.18 55)" />
            </svg>
            <p class="text-xs text-text-secondary mt-1">16px</p>
          </div>
        </div>
        <div class="mt-4 flex items-center gap-3 px-3 py-2 rounded-lg bg-surface-alt border w-fit">
          <svg width="24" height="24" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="4" y="8" width="22" height="22" rx="3" fill="oklch(0.50 0.18 55)" opacity="0.5" />
            <rect x="14" y="10" width="22" height="22" rx="3" fill="oklch(0.50 0.18 55)" />
          </svg>
          <span class="font-bold text-sm">@izharikov</span>
        </div>
      </div>

      {/* C3 — Hexagon */}
      <div>
        <h3 class="font-semibold mb-1">C3 — Hexagon</h3>
        <p class="text-sm text-text-secondary mb-4">Classic hex. Dev/tech associations, compact.</p>
        <div class="flex items-end gap-6">
          <div>
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <polygon points="20,3 36,11 36,29 20,37 4,29 4,11" fill="oklch(0.50 0.18 55)" />
            </svg>
            <p class="text-xs text-text-secondary mt-1">40px</p>
          </div>
          <div>
            <svg width="32" height="32" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <polygon points="20,3 36,11 36,29 20,37 4,29 4,11" fill="oklch(0.50 0.18 55)" />
            </svg>
            <p class="text-xs text-text-secondary mt-1">32px</p>
          </div>
          <div>
            <svg width="16" height="16" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <polygon points="20,3 36,11 36,29 20,37 4,29 4,11" fill="oklch(0.50 0.18 55)" />
            </svg>
            <p class="text-xs text-text-secondary mt-1">16px</p>
          </div>
        </div>
        <div class="mt-4 flex items-center gap-3 px-3 py-2 rounded-lg bg-surface-alt border w-fit">
          <svg width="24" height="24" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <polygon points="20,3 36,11 36,29 20,37 4,29 4,11" fill="oklch(0.50 0.18 55)" />
          </svg>
          <span class="font-bold text-sm">@izharikov</span>
        </div>
      </div>

      {/* C4 — Split square */}
      <div>
        <h3 class="font-semibold mb-1">C4 — Split Square</h3>
        <p class="text-sm text-text-secondary mb-4">Square split diagonally. Two tones of amber.</p>
        <div class="flex items-end gap-6">
          <div>
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M6 6h28v28H6z" fill="oklch(0.50 0.18 55)" rx="3" />
              <path d="M6 6l28 28H6z" fill="oklch(0.40 0.18 55)" />
              <rect x="6" y="6" width="28" height="28" rx="3" fill="none" />
              <clipPath id="c4a"><rect x="6" y="6" width="28" height="28" rx="3" /></clipPath>
              <g clip-path="url(#c4a)">
                <rect x="6" y="6" width="28" height="28" fill="oklch(0.50 0.18 55)" />
                <polygon points="6,6 6,34 34,34" fill="oklch(0.38 0.16 55)" />
              </g>
            </svg>
            <p class="text-xs text-text-secondary mt-1">40px</p>
          </div>
          <div>
            <svg width="32" height="32" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <clipPath id="c4b"><rect x="6" y="6" width="28" height="28" rx="3" /></clipPath>
              <g clip-path="url(#c4b)">
                <rect x="6" y="6" width="28" height="28" fill="oklch(0.50 0.18 55)" />
                <polygon points="6,6 6,34 34,34" fill="oklch(0.38 0.16 55)" />
              </g>
            </svg>
            <p class="text-xs text-text-secondary mt-1">32px</p>
          </div>
          <div>
            <svg width="16" height="16" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <clipPath id="c4c"><rect x="6" y="6" width="28" height="28" rx="3" /></clipPath>
              <g clip-path="url(#c4c)">
                <rect x="6" y="6" width="28" height="28" fill="oklch(0.50 0.18 55)" />
                <polygon points="6,6 6,34 34,34" fill="oklch(0.38 0.16 55)" />
              </g>
            </svg>
            <p class="text-xs text-text-secondary mt-1">16px</p>
          </div>
        </div>
        <div class="mt-4 flex items-center gap-3 px-3 py-2 rounded-lg bg-surface-alt border w-fit">
          <svg width="24" height="24" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <clipPath id="c4d"><rect x="6" y="6" width="28" height="28" rx="3" /></clipPath>
            <g clip-path="url(#c4d)">
              <rect x="6" y="6" width="28" height="28" fill="oklch(0.50 0.18 55)" />
              <polygon points="6,6 6,34 34,34" fill="oklch(0.38 0.16 55)" />
            </g>
          </svg>
          <span class="font-bold text-sm">@izharikov</span>
        </div>
      </div>

      {/* C5 — Circle cutout */}
      <div>
        <h3 class="font-semibold mb-1">C5 — Circle Cutout</h3>
        <p class="text-sm text-text-secondary mb-4">Solid circle with a geometric notch cut out.</p>
        <div class="flex items-end gap-6">
          <div>
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <mask id="c5a"><circle cx="20" cy="20" r="17" fill="white" /><rect x="22" y="4" width="12" height="12" rx="2" fill="black" /></mask>
              <circle cx="20" cy="20" r="17" fill="oklch(0.50 0.18 55)" mask="url(#c5a)" />
            </svg>
            <p class="text-xs text-text-secondary mt-1">40px</p>
          </div>
          <div>
            <svg width="32" height="32" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <mask id="c5b"><circle cx="20" cy="20" r="17" fill="white" /><rect x="22" y="4" width="12" height="12" rx="2" fill="black" /></mask>
              <circle cx="20" cy="20" r="17" fill="oklch(0.50 0.18 55)" mask="url(#c5b)" />
            </svg>
            <p class="text-xs text-text-secondary mt-1">32px</p>
          </div>
          <div>
            <svg width="16" height="16" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <mask id="c5c"><circle cx="20" cy="20" r="17" fill="white" /><rect x="22" y="4" width="12" height="12" rx="2" fill="black" /></mask>
              <circle cx="20" cy="20" r="17" fill="oklch(0.50 0.18 55)" mask="url(#c5c)" />
            </svg>
            <p class="text-xs text-text-secondary mt-1">16px</p>
          </div>
        </div>
        <div class="mt-4 flex items-center gap-3 px-3 py-2 rounded-lg bg-surface-alt border w-fit">
          <svg width="24" height="24" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <mask id="c5d"><circle cx="20" cy="20" r="17" fill="white" /><rect x="22" y="4" width="12" height="12" rx="2" fill="black" /></mask>
            <circle cx="20" cy="20" r="17" fill="oklch(0.50 0.18 55)" mask="url(#c5d)" />
          </svg>
          <span class="font-bold text-sm">@izharikov</span>
        </div>
      </div>

      {/* C6 — Stacked bars */}
      <div>
        <h3 class="font-semibold mb-1">C6 — Stacked Bars</h3>
        <p class="text-sm text-text-secondary mb-4">Three horizontal bars, descending width. Signal/growth motif.</p>
        <div class="flex items-end gap-6">
          <div>
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="6" y="7" width="28" height="7" rx="2" fill="oklch(0.50 0.18 55)" />
              <rect x="6" y="17" width="20" height="7" rx="2" fill="oklch(0.50 0.18 55)" opacity="0.7" />
              <rect x="6" y="27" width="12" height="7" rx="2" fill="oklch(0.50 0.18 55)" opacity="0.4" />
            </svg>
            <p class="text-xs text-text-secondary mt-1">40px</p>
          </div>
          <div>
            <svg width="32" height="32" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="6" y="7" width="28" height="7" rx="2" fill="oklch(0.50 0.18 55)" />
              <rect x="6" y="17" width="20" height="7" rx="2" fill="oklch(0.50 0.18 55)" opacity="0.7" />
              <rect x="6" y="27" width="12" height="7" rx="2" fill="oklch(0.50 0.18 55)" opacity="0.4" />
            </svg>
            <p class="text-xs text-text-secondary mt-1">32px</p>
          </div>
          <div>
            <svg width="16" height="16" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="6" y="7" width="28" height="7" rx="2" fill="oklch(0.50 0.18 55)" />
              <rect x="6" y="17" width="20" height="7" rx="2" fill="oklch(0.50 0.18 55)" opacity="0.7" />
              <rect x="6" y="27" width="12" height="7" rx="2" fill="oklch(0.50 0.18 55)" opacity="0.4" />
            </svg>
            <p class="text-xs text-text-secondary mt-1">16px</p>
          </div>
        </div>
        <div class="mt-4 flex items-center gap-3 px-3 py-2 rounded-lg bg-surface-alt border w-fit">
          <svg width="24" height="24" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="6" y="7" width="28" height="7" rx="2" fill="oklch(0.50 0.18 55)" />
            <rect x="6" y="17" width="20" height="7" rx="2" fill="oklch(0.50 0.18 55)" opacity="0.7" />
            <rect x="6" y="27" width="12" height="7" rx="2" fill="oklch(0.50 0.18 55)" opacity="0.4" />
          </svg>
          <span class="font-bold text-sm">@izharikov</span>
        </div>
      </div>
    </div>

    {/* ── 3D / Isometric Marks ── */}
    <h2 class="text-2xl font-semibold border-b pb-2 mb-8">3D / Isometric</h2>

    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-3 mb-16">

      {/* C7 — Iso cube */}
      <div>
        <h3 class="font-semibold mb-1">C7 — Isometric Cube</h3>
        <p class="text-sm text-text-secondary mb-4">Classic iso cube. Three faces, three amber tones.</p>
        <div class="flex items-end gap-6">
          <div>
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <polygon points="20,4 36,13 36,27 20,36 4,27 4,13" fill="none" />
              {/* Top face */}
              <polygon points="20,4 36,13 20,22 4,13" fill="oklch(0.55 0.18 55)" />
              {/* Left face */}
              <polygon points="4,13 20,22 20,36 4,27" fill="oklch(0.42 0.16 55)" />
              {/* Right face */}
              <polygon points="36,13 20,22 20,36 36,27" fill="oklch(0.48 0.18 55)" />
            </svg>
            <p class="text-xs text-text-secondary mt-1">40px</p>
          </div>
          <div>
            <svg width="32" height="32" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <polygon points="20,4 36,13 20,22 4,13" fill="oklch(0.55 0.18 55)" />
              <polygon points="4,13 20,22 20,36 4,27" fill="oklch(0.42 0.16 55)" />
              <polygon points="36,13 20,22 20,36 36,27" fill="oklch(0.48 0.18 55)" />
            </svg>
            <p class="text-xs text-text-secondary mt-1">32px</p>
          </div>
          <div>
            <svg width="16" height="16" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <polygon points="20,4 36,13 20,22 4,13" fill="oklch(0.55 0.18 55)" />
              <polygon points="4,13 20,22 20,36 4,27" fill="oklch(0.42 0.16 55)" />
              <polygon points="36,13 20,22 20,36 36,27" fill="oklch(0.48 0.18 55)" />
            </svg>
            <p class="text-xs text-text-secondary mt-1">16px</p>
          </div>
        </div>
        <div class="mt-4 flex items-center gap-3 px-3 py-2 rounded-lg bg-surface-alt border w-fit">
          <svg width="24" height="24" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <polygon points="20,4 36,13 20,22 4,13" fill="oklch(0.55 0.18 55)" />
            <polygon points="4,13 20,22 20,36 4,27" fill="oklch(0.42 0.16 55)" />
            <polygon points="36,13 20,22 20,36 36,27" fill="oklch(0.48 0.18 55)" />
          </svg>
          <span class="font-bold text-sm">@izharikov</span>
        </div>
      </div>

      {/* C8 — Iso steps */}
      <div>
        <h3 class="font-semibold mb-1">C8 — Isometric Steps</h3>
        <p class="text-sm text-text-secondary mb-4">Three ascending iso blocks. Growth, building, stacking.</p>
        <div class="flex items-end gap-6">
          <div>
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              {/* Step 1 (lowest, left) */}
              <polygon points="4,28 14,23 14,33 4,38" fill="oklch(0.42 0.16 55)" />
              <polygon points="14,23 24,28 24,38 14,33" fill="oklch(0.48 0.18 55)" />
              <polygon points="4,28 14,23 24,28 14,33" fill="oklch(0.55 0.18 55)" />
              {/* Step 2 (middle) */}
              <polygon points="10,20 20,15 20,25 10,30" fill="oklch(0.42 0.16 55)" />
              <polygon points="20,15 30,20 30,30 20,25" fill="oklch(0.48 0.18 55)" />
              <polygon points="10,20 20,15 30,20 20,25" fill="oklch(0.55 0.18 55)" />
              {/* Step 3 (highest, right) */}
              <polygon points="16,12 26,7 26,17 16,22" fill="oklch(0.42 0.16 55)" />
              <polygon points="26,7 36,12 36,22 26,17" fill="oklch(0.48 0.18 55)" />
              <polygon points="16,12 26,7 36,12 26,17" fill="oklch(0.55 0.18 55)" />
            </svg>
            <p class="text-xs text-text-secondary mt-1">40px</p>
          </div>
          <div>
            <svg width="32" height="32" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <polygon points="4,28 14,23 14,33 4,38" fill="oklch(0.42 0.16 55)" />
              <polygon points="14,23 24,28 24,38 14,33" fill="oklch(0.48 0.18 55)" />
              <polygon points="4,28 14,23 24,28 14,33" fill="oklch(0.55 0.18 55)" />
              <polygon points="10,20 20,15 20,25 10,30" fill="oklch(0.42 0.16 55)" />
              <polygon points="20,15 30,20 30,30 20,25" fill="oklch(0.48 0.18 55)" />
              <polygon points="10,20 20,15 30,20 20,25" fill="oklch(0.55 0.18 55)" />
              <polygon points="16,12 26,7 26,17 16,22" fill="oklch(0.42 0.16 55)" />
              <polygon points="26,7 36,12 36,22 26,17" fill="oklch(0.48 0.18 55)" />
              <polygon points="16,12 26,7 36,12 26,17" fill="oklch(0.55 0.18 55)" />
            </svg>
            <p class="text-xs text-text-secondary mt-1">32px</p>
          </div>
          <div>
            <svg width="16" height="16" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <polygon points="4,28 14,23 14,33 4,38" fill="oklch(0.42 0.16 55)" />
              <polygon points="14,23 24,28 24,38 14,33" fill="oklch(0.48 0.18 55)" />
              <polygon points="4,28 14,23 24,28 14,33" fill="oklch(0.55 0.18 55)" />
              <polygon points="10,20 20,15 20,25 10,30" fill="oklch(0.42 0.16 55)" />
              <polygon points="20,15 30,20 30,30 20,25" fill="oklch(0.48 0.18 55)" />
              <polygon points="10,20 20,15 30,20 20,25" fill="oklch(0.55 0.18 55)" />
              <polygon points="16,12 26,7 26,17 16,22" fill="oklch(0.42 0.16 55)" />
              <polygon points="26,7 36,12 36,22 26,17" fill="oklch(0.48 0.18 55)" />
              <polygon points="16,12 26,7 36,12 26,17" fill="oklch(0.55 0.18 55)" />
            </svg>
            <p class="text-xs text-text-secondary mt-1">16px</p>
          </div>
        </div>
        <div class="mt-4 flex items-center gap-3 px-3 py-2 rounded-lg bg-surface-alt border w-fit">
          <svg width="24" height="24" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <polygon points="4,28 14,23 14,33 4,38" fill="oklch(0.42 0.16 55)" />
            <polygon points="14,23 24,28 24,38 14,33" fill="oklch(0.48 0.18 55)" />
            <polygon points="4,28 14,23 24,28 14,33" fill="oklch(0.55 0.18 55)" />
            <polygon points="10,20 20,15 20,25 10,30" fill="oklch(0.42 0.16 55)" />
            <polygon points="20,15 30,20 30,30 20,25" fill="oklch(0.48 0.18 55)" />
            <polygon points="10,20 20,15 30,20 20,25" fill="oklch(0.55 0.18 55)" />
            <polygon points="16,12 26,7 26,17 16,22" fill="oklch(0.42 0.16 55)" />
            <polygon points="26,7 36,12 36,22 26,17" fill="oklch(0.48 0.18 55)" />
            <polygon points="16,12 26,7 36,12 26,17" fill="oklch(0.55 0.18 55)" />
          </svg>
          <span class="font-bold text-sm">@izharikov</span>
        </div>
      </div>

      {/* C9 — Folded plane */}
      <div>
