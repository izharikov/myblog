---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { getSlug } from '@/lib/blog';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { resolveImage } from '@/lib/images';
import { parseDate, formatDate } from '@/lib/date';
import { siteConfig } from '@/config/site';
import profileImg from '@/images/profile.jpg';

if (import.meta.env.PROD) {
  return Astro.redirect('/');
}

const posts = await getCollection('blog');
const sorted = posts
  .sort((a, b) => parseDate(b.data.date).getTime() - parseDate(a.data.date).getTime())
  .slice(0, 10)
  .map(post => ({
    title: post.data.title,
    description: post.data.description,
    slug: getSlug(post),
    logo: post.data.logo,
    dateDisplay: formatDate(parseDate(post.data.date)),
    tags: post.data.tags,
  }));

const grouped = sorted.reduce<Record<string, typeof sorted>>((acc, post) => {
  const year = post.dateDisplay.split(', ').pop()!;
  (acc[year] ??= []).push(post);
  return acc;
}, {});
const years = Object.keys(grouped).sort((a, b) => +b - +a);
---

<BaseLayout title="Hero Preview" description="Dev-only hero layout comparison">
  <div class="max-w-screen-xl mx-auto px-4 py-8">
    <div class="mb-8 rounded-lg border bg-surface-alt p-4 text-sm text-text-secondary">
      Dev-only preview &mdash; comparing hero layout options with real blog data.
    </div>

    {/* ══════ Option 3: Left-aligned with socials ══════ */}
    <section class="mb-24">
      <div class="mb-6">
        <span class="text-xs font-medium text-accent bg-code-bg px-2 py-1 rounded">Option 3</span>
        <h2 class="text-2xl font-semibold mt-2">Left-aligned with Socials</h2>
        <p class="text-sm text-text-secondary">Compact hero flowing into timeline. Social links inline.</p>
      </div>

      <div class="rounded-xl border bg-surface overflow-hidden">
        {/* Hero */}
        <div class="px-6 pt-8 pb-6">
          <div class="flex items-center gap-5">
            <Image src={profileImg} alt={siteConfig.author.name} width={72} height={72} class="rounded-full shrink-0" quality={90} />
            <div>
              <h1 class="text-2xl font-bold tracking-tight">
                {siteConfig.author.name}
              </h1>
              <p class="text-text-secondary mt-1">{siteConfig.description}</p>
              <div class="flex items-center gap-3 mt-2">
                <a href={siteConfig.social.github} class="text-text-secondary hover:text-accent transition-colors">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                </a>
                <a href={siteConfig.social.linkedin} class="text-text-secondary hover:text-accent transition-colors">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
                <a href={siteConfig.social.twitter} class="text-text-secondary hover:text-accent transition-colors">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
              </div>
            </div>
          </div>
        </div>

        {/* Timeline */}
        <div class="px-6 pb-8">
          <h2 class="text-xl font-bold tracking-tight mb-6">Latest Posts</h2>
          {years.map(year => (
            <div class="mb-6">
              <h3 class="text-lg font-bold mb-3 text-text-secondary">{year}</h3>
              <div class="space-y-1">
                {grouped[year].map(post => {
                  const logoFn = resolveImage(post.logo);
                  return (
                    <a href={`/blogs/${post.slug}`} class="flex items-center gap-4 py-3 px-3 -mx-3 rounded-lg hover:bg-surface-alt transition-colors group">
                      {logoFn ? (
                        <Image src={logoFn()} alt="" class="hidden sm:block w-28 h-14 rounded-lg border object-cover shrink-0" width={400} quality={90} />
                      ) : (
                        <div class="hidden sm:block w-28 h-14 rounded-lg bg-surface-alt border shrink-0" />
                      )}
                      <div class="min-w-0 flex-1">
                        <span class="font-medium group-hover:text-accent transition-colors">{post.title}</span>
                        <p class="text-sm text-text-secondary mt-0.5 line-clamp-1">{post.description}</p>
                        <div class="flex items-center gap-3 mt-1">
                          <time class="text-xs text-text-secondary">{post.dateDisplay}</time>
                          <div class="flex gap-1.5">
                            {post.tags.map(t => <span class="text-xs font-medium text-accent bg-code-bg px-1.5 py-0.5 rounded">{t}</span>)}
                          </div>
                        </div>
                      </div>
                    </a>
                  );
                })}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ══════ Option 4: Sidebar identity ══════ */}
    <section class="mb-24">
      <div class="mb-6">
        <span class="text-xs font-medium text-accent bg-code-bg px-2 py-1 rounded">Option 4</span>
        <h2 class="text-2xl font-semibold mt-2">Sidebar Identity</h2>
        <p class="text-sm text-text-secondary">Photo + bio in sticky left sidebar, timeline on the right.</p>
      </div>

      <div class="rounded-xl border bg-surface overflow-hidden">
        <div class="md:flex">
          {/* Sidebar */}
          <aside class="md:w-64 lg:w-72 shrink-0 border-b md:border-b-0 md:border-r p-6 md:sticky md:top-0 md:self-start">
            <div class="flex md:flex-col items-center md:items-start gap-4">
              <Image src={profileImg} alt={siteConfig.author.name} width={96} height={96} class="rounded-full shrink-0" quality={90} />
              <div class="md:mt-2">
                <h1 class="text-xl font-bold tracking-tight">{siteConfig.author.name}</h1>
                <p class="text-sm text-text-secondary mt-1">{siteConfig.description}</p>
                <div class="flex items-center gap-3 mt-3">
                  <a href={siteConfig.social.github} class="text-text-secondary hover:text-accent transition-colors">
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                  </a>
                  <a href={siteConfig.social.linkedin} class="text-text-secondary hover:text-accent transition-colors">
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  </a>
                  <a href={siteConfig.social.twitter} class="text-text-secondary hover:text-accent transition-colors">
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  </a>
                </div>
              </div>
            </div>
          </aside>

          {/* Timeline */}
          <div class="flex-1 p-6">
            <h2 class="text-xl font-bold tracking-tight mb-6">Latest Posts</h2>
            {years.map(year => (
              <div class="mb-6">
                <h3 class="text-lg font-bold mb-3 text-text-secondary">{year}</h3>
                <div class="space-y-1">
                  {grouped[year].map(post => {
                    const logoFn = resolveImage(post.logo);
                    return (
                      <a href={`/blogs/${post.slug}`} class="flex items-center gap-4 py-3 px-3 -mx-3 rounded-lg hover:bg-surface-alt transition-colors group">
                        {logoFn ? (
                          <Image src={logoFn()} alt="" class="hidden sm:block w-28 h-14 rounded-lg border object-cover shrink-0" width={400} quality={90} />
                        ) : (
                          <div class="hidden sm:block w-28 h-14 rounded-lg bg-surface-alt border shrink-0" />
                        )}
                        <div class="min-w-0 flex-1">
                          <span class="font-medium group-hover:text-accent transition-colors">{post.title}</span>
                          <p class="text-sm text-text-secondary mt-0.5 line-clamp-1">{post.description}</p>
                          <div class="flex items-center gap-3 mt-1">
                            <time class="text-xs text-text-secondary">{post.dateDisplay}</time>
                            <div class="flex gap-1.5">
                              {post.tags.map(t => <span class="text-xs font-medium text-accent bg-code-bg px-1.5 py-0.5 rounded">{t}</span>)}
                            </div>
                          </div>
                        </div>
                      </a>
                    );
                  })}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
