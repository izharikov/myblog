---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Dev only — redirect to home in production
if (import.meta.env.PROD) {
  return Astro.redirect('/');
}
---

<BaseLayout title="Design Preview" description="Dev-only design token preview">
  <div class="max-w-3xl mx-auto py-12 px-4">
    <div class="mb-8 rounded-lg border bg-surface-alt p-4 text-sm text-text-secondary">
      Dev-only preview &mdash; not included in production builds.
    </div>

    <section class="mb-12">
      <h1 class="text-4xl font-bold tracking-tight mb-2">Typography Scale</h1>
      <p class="text-text-secondary mb-6">Space Grotesk + IBM Plex Mono</p>

      <div class="space-y-4">
        <h1 class="text-4xl font-bold tracking-tight">h1 &mdash; Building an MCP Server</h1>
        <h2 class="text-3xl font-semibold tracking-tight border-b pb-2">h2 &mdash; Why MCP on the Edge?</h2>
        <h3 class="text-2xl font-semibold tracking-tight">h3 &mdash; Getting Started</h3>
        <h4 class="text-xl font-semibold tracking-tight">h4 &mdash; Configuration</h4>
        <p class="leading-7 text-text-secondary">
          Body text &mdash; The Model Context Protocol is changing how AI agents interact with external
          services. In this post, we build a production-ready MCP server that runs
          on Cloudflare Workers, handling <code>tool/list</code> and <code>tool/call</code> requests.
        </p>
        <p class="text-sm text-text-secondary">Small / meta text &mdash; March 15, 2026 &middot; 8 min read</p>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-3xl font-semibold tracking-tight border-b pb-2 mb-6">Color Tokens</h2>
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
        <div>
          <div class="h-16 rounded-md bg-surface border"></div>
          <p class="mt-1 text-xs text-text-secondary">surface</p>
        </div>
        <div>
          <div class="h-16 rounded-md bg-surface-alt border"></div>
          <p class="mt-1 text-xs text-text-secondary">surface-alt</p>
        </div>
        <div>
          <div class="h-16 rounded-md bg-accent"></div>
          <p class="mt-1 text-xs text-text-secondary">accent</p>
        </div>
        <div>
          <div class="h-16 rounded-md bg-accent-hover"></div>
          <p class="mt-1 text-xs text-text-secondary">accent-hover</p>
        </div>
        <div>
          <div class="h-16 rounded-md bg-code-bg border"></div>
          <p class="mt-1 text-xs text-text-secondary">code-bg</p>
        </div>
        <div>
          <div class="h-16 rounded-md bg-destructive"></div>
          <p class="mt-1 text-xs text-text-secondary">destructive</p>
        </div>
        <div>
          <div class="h-16 rounded-md border-2 border-border bg-surface"></div>
          <p class="mt-1 text-xs text-text-secondary">border</p>
        </div>
        <div class="flex flex-col justify-end">
          <p class="text-text-primary text-sm font-medium">text-primary</p>
          <p class="text-text-secondary text-sm">text-secondary</p>
          <p class="text-accent text-sm font-medium">accent link</p>
        </div>
      </div>
    </section>

    <section class="mb-12 prose">
      <h2>Prose Content Sample</h2>
      <p>
        Running MCP servers on edge infrastructure gives you sub-50ms latency
        globally. Combined with <a href="#">Durable Objects</a> for state management,
        it is the ideal platform for AI tool servers.
      </p>
      <p>
        This paragraph has <strong>bold text</strong>, <em>italic text</em>,
        and <code>inline code</code> styling. Links look like <a href="#">this anchor</a>.
      </p>
      <ul>
        <li>First unordered item with some detail</li>
        <li>Second item referencing <code>McpServer</code></li>
        <li>Third item with a <a href="#">link inside</a></li>
      </ul>
      <ol>
        <li>Step one: install dependencies</li>
        <li>Step two: configure the server</li>
        <li>Step three: deploy to Cloudflare</li>
      </ol>
      <hr />
      <table>
        <thead>
          <tr><th>Feature</th><th>Workers</th><th>Pages</th></tr>
        </thead>
        <tbody>
          <tr><td>Static assets</td><td>Via KV</td><td>Built-in CDN</td></tr>
          <tr><td>Server logic</td><td>Full runtime</td><td>Functions only</td></tr>
        </tbody>
      </table>
    </section>

    <section class="mb-12">
      <h2 class="text-3xl font-semibold tracking-tight border-b pb-2 mb-6">Code Block</h2>
      <div class="relative rounded-lg overflow-hidden border">
        <pre class="astro-code overflow-x-auto p-4 text-sm bg-code-bg"><code>const server = new McpServer(&#123; name: "demo" &#125;);</code></pre>
      </div>
      <p class="mt-2 text-xs text-text-secondary">
        Note: full Shiki highlighting only applies to MDX-rendered code blocks.
      </p>
    </section>

    <section class="mb-12">
      <h2 class="text-3xl font-semibold tracking-tight border-b pb-2 mb-6">Blog Cards</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        <a href="#" class="group block rounded-lg border bg-surface p-5 transition-colors hover:bg-surface-alt">
          <div class="flex gap-2 mb-2">
            <span class="text-xs font-medium text-accent bg-code-bg px-2 py-0.5 rounded">Astro</span>
            <span class="text-xs font-medium text-accent bg-code-bg px-2 py-0.5 rounded">Migration</span>
          </div>
          <h3 class="font-semibold group-hover:text-accent transition-colors">Migrating from Next.js to Astro</h3>
          <p class="mt-1 text-sm text-text-secondary leading-relaxed">A practical guide to moving a content-heavy site to Astro island architecture.</p>
        </a>
        <a href="#" class="group block rounded-lg border bg-surface p-5 transition-colors hover:bg-surface-alt">
          <div class="flex gap-2 mb-2">
            <span class="text-xs font-medium text-accent bg-code-bg px-2 py-0.5 rounded">Sitecore</span>
            <span class="text-xs font-medium text-accent bg-code-bg px-2 py-0.5 rounded">DevOps</span>
          </div>
          <h3 class="font-semibold group-hover:text-accent transition-colors">CI/CD for Sitecore XM Cloud</h3>
          <p class="mt-1 text-sm text-text-secondary leading-relaxed">Setting up automated deployments with GitHub Actions and the Sitecore CLI.</p>
        </a>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-3xl font-semibold tracking-tight border-b pb-2 mb-6">Interactive Elements</h2>
      <div class="flex flex-wrap gap-3">
        <button class="px-4 py-2 rounded-md bg-accent text-surface font-medium hover:bg-accent-hover transition-colors">
          Primary Button
        </button>
        <button class="px-4 py-2 rounded-md border bg-surface font-medium hover:bg-surface-alt transition-colors">
          Secondary Button
        </button>
        <button class="px-4 py-2 rounded-md bg-destructive text-white font-medium hover:opacity-90 transition-opacity">
          Destructive
        </button>
      </div>
      <div class="mt-4 flex flex-wrap gap-2">
        <span class="text-xs font-medium text-accent bg-code-bg px-2 py-1 rounded">Tag One</span>
        <span class="text-xs font-medium text-accent bg-code-bg px-2 py-1 rounded">Tag Two</span>
        <span class="text-xs font-medium text-accent bg-code-bg px-2 py-1 rounded">Tag Three</span>
      </div>
    </section>
  </div>
</BaseLayout>
